generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String?
  role       String    @default("MERCHANT") // ADMIN, MERCHANT, AGENT, STAFF
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  merchantId String?
  createdAt  DateTime  @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  businessName     String?
  email            String           @unique
  address          String?
  phone            String?
  status           String           @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  walletBalance    Decimal          @default(0) @db.Decimal(14,2)
  commissionRate   Decimal          @default(0) @db.Decimal(5,2)
  
  // Whitelist & Integration
  ipWhitelist      String?          // Comma separated IPs
  webhookWhitelist String?          // Optional: restricted webhook origins
  webhookUrl       String?          
  webhookSecret    String?          // HMAC signing secret
  redirectUrl      String?          
  trialEndsAt      DateTime?        
  telegramBotToken String?          
  telegramChatId   String?          
  
  disableWallet    Boolean          @default(false) // If true, merchant can process payments without balance
  
  // Relations
  users            User[]
  apiKeys          ApiKey[]
  paymentIntents   PaymentIntent[]
  gpayAccounts     GooglePayAccount[]
  ledgerEntries    WalletLedger[]
  settlements      Settlement[]
  ipWhitelistRequests IpWhitelistRequest[]
  webhookLogs      WebhookLog[]
  webhookEvents    WebhookEvent[]
  agent            Agent?           @relation(fields: [agentId], references: [id])
  agentId          String?
  
  apiAccessStatus  String           @default("NOT_REQUESTED") // NOT_REQUESTED, PENDING, APPROVED
  processingMode   String           @default("OWN_ACCOUNT")    // OWN_ACCOUNT, PLATFORM_POOL
  
  // Custom Branding
  brandColor       String?          @default("#2563eb") // Primary brand color
  brandLogo        String?          // URL to merchant logo
  brandName        String?          // Display name on checkout
  showSupportEmail Boolean          @default(true)
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Agent {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  referralCode   String     @unique
  commissionRate Decimal    @default(0) @db.Decimal(5,2)
  walletBalance  Decimal    @default(0) @db.Decimal(14,2)
  merchants      Merchant[]
  commissionLogs AgentCommissionLog[]
  createdAt      DateTime   @default(now())
}

model AgentCommissionLog {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id])
  merchantId      String
  amount          Decimal  @db.Decimal(14,2)
  description     String?
  paymentIntentId String?
  createdAt       DateTime @default(now())
}

model WalletLedger {
  id            String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  type          String   // CREDIT, DEBIT
  amount        Decimal  @db.Decimal(14,2)
  description   String?
  balanceAfter  Decimal  @db.Decimal(14,2)
  referenceType String?  // TRANSACTION, RECHARGE, PAYOUT
  referenceId   String?
  createdAt     DateTime @default(now())
}

model ApiKey {
  id           String          @id @default(cuid())
  key          String          @unique
  merchantId   String
  merchant     Merchant        @relation(fields: [merchantId], references: [id])
  monthlyLimit Decimal         @default(100000) @db.Decimal(14,2)
  usedAmount   Decimal         @default(0) @db.Decimal(14,2)
  isBlocked    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  paymentIntents PaymentIntent[]
}

model PaymentIntent {
  id               String      @id @default(cuid())
  merchantId       String
  merchant         Merchant    @relation(fields: [merchantId], references: [id])
  apiKeyId         String
  apiKey           ApiKey      @relation(fields: [apiKeyId], references: [id])
  amount           Decimal     @db.Decimal(14,2)
  status           String      @default("PENDING") // PENDING, SUCCESS, FAILED, EXPIRED
  referenceId      String      @unique // order_id from merchant
  customerMobile   String?
  customerEmail    String?
  redirectUrl      String?
  merchantName     String?
  upiDeepLink      String?
  qrData           String?
  paymentToken     String?     @unique // for hosted pages
  payerName        String?
  payerUpiId       String?
  transactionId    String?     @unique // linked after verification
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
  
  // Risk Engine & Customer Tracking
  customerId       String?
  customer         Customer?   @relation(fields: [customerId], references: [id])
  customerRiskTier String      @default("HIGH") // Snapshot of risk at time of txn
  
  // Auditing & Manual Flow
  isManualApproval Boolean     @default(false)
  approvalIp       String?     
  
  isRecharge       Boolean     @default(false)
  createdAt        DateTime    @default(now())
  expireAt         DateTime?
  updatedAt        DateTime    @updatedAt
}

model Transaction {
  id            String         @id @default(cuid())
  externalId    String         @unique // merchantTransactionId from GPay
  utr           String?
  amount        Decimal        @db.Decimal(14,2)
  payerName     String?
  payerUpiId    String?
  note          String?
  timestamp     DateTime       @default(now())
  paymentIntent PaymentIntent?
}

model PaymentLink {
  id           String   @id @default(cuid())
  merchantId   String
  title        String
  amount       Decimal  @db.Decimal(14,2)
  description  String?
  slug         String   @unique
  apiKeyId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model GooglePayAccount {
  id             String    @id @default(cuid())
  merchantId     String
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  name           String
  email          String
  upiId          String
  reportId       String?
  status         String    @default("ACTIVE")
  desiredStatus  String    @default("STOP") // START, STOP, LOGIN_AUTO, LOGIN_MANUAL, WAITING_OTP, OTP_READY
  botPassword    String?   // For remote auto-login
  otpCode        String?   // Temporary storage for OTP
  lastHeartbeat  DateTime?
  lastSync       DateTime?
  
  // === Staff Workflow & Account Lifecycle ===
  accountType    String    @default("MERCHANT_OWNED") // MERCHANT_OWNED, PLATFORM_POOL
  reviewStatus   String    @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, SUSPENDED
  sessionStatus  String    @default("OFFLINE")        // OFFLINE, STARTING, ONLINE, EXPIRED, ERROR
  reviewedBy     String?   // Staff user ID who approved/rejected
  reviewedAt     DateTime?
  reviewNote     String?   // Staff can leave notes
  assignedStaff  String?   // Staff member currently managing this session
  
  // VPA Lifecycle & Risk Engine
  vendorType     String    @default("GPAY") // GPAY, PAYTM, PINELABS
  riskTier       String    @default("HIGH") // HIGH, MID, LOW
  healthScore    Decimal   @default(100) @db.Decimal(5,2)
  cooldownUntil  DateTime?
  successfulTxn  Int       @default(0)
  poolAssignments VPAPoolAssignment[]
  
  isAdmin        Boolean   @default(false) 
  proxyConfig    String?   // Format: http://user:pass@ip:port
  
  // Advanced SaaS Limits
  minTicket      Decimal   @default(0) @db.Decimal(14,2)
  maxTicket      Decimal   @default(1000000) @db.Decimal(14,2)
  dailyLimit     Decimal   @default(0) @db.Decimal(14,2)
  weeklyLimit    Decimal   @default(0) @db.Decimal(14,2)
  monthlyLimit   Decimal   @default(0) @db.Decimal(14,2)
  
  currentDaily   Decimal   @default(0) @db.Decimal(14,2)
  currentWeekly  Decimal   @default(0) @db.Decimal(14,2)
  currentMonthly Decimal   @default(0) @db.Decimal(14,2)
  
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  metadata    String?  // JSON string
  timestamp   DateTime @default(now())
}

model ApiLog {
  id        String   @id @default(cuid())
  merchantId String?
  level     String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR, CRITICAL
  message   String
  metadata  String?  // JSON string
  timestamp DateTime @default(now())
}

model IpWhitelistRequest {
  id            String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  ipAddress     String
  webhookUrl    String?
  acceptedTerms Boolean  @default(false)
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  note          String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WebhookLog {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  event       String
  payload     String   // JSON string
  url         String
  status      Int?     // HTTP status code
  response    String?  // Response body
  isSuccess   Boolean  @default(false)
  attempts    Int      @default(1)
  createdAt   DateTime @default(now())
}

model WebhookEvent {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  event       String
  payload     String   // JSON string
  url         String
  status      String   @default("PENDING") // PENDING, FAILED, SUCCESS
  retryCount  Int      @default(0)
  nextRetryAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// RISK ENGINE & VPA LIFECYCLE MANAGEMENT
// ==========================================

model Customer {
  id                String   @id @default(cuid())
  fingerprint       String   @unique // hash(device+ip+phone)
  phone             String?
  deviceId          String?
  ipAddress         String?
  riskTier          String   @default("HIGH") // HIGH, MID, LOW
  successfulTxnCount Int     @default(0)
  totalVolume       Decimal  @default(0) @db.Decimal(14,2)
  firstSeenAt       DateTime @default(now())
  lastTxnAt         DateTime?
  isFTD             Boolean  @default(true) // First Time Depositor
  paymentIntents    PaymentIntent[]
}

model BankPool {
  id        String   @id @default(cuid())
  name      String   // "High-Risk Pool", "Default Pool", "VIP Pool"
  riskTiers String   // "HIGH", "HIGH,MID", "LOW"
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  accounts  VPAPoolAssignment[]
}

model VPAPoolAssignment {
  id          String           @id @default(cuid())
  poolId      String
  pool        BankPool         @relation(fields: [poolId], references: [id], onDelete: Cascade)
  accountId   String
  account     GooglePayAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  priority    Int              @default(0)
  
  @@unique([poolId, accountId])
}

// NEW: Routing Audit
model RoutingDecision {
  id              String   @id @default(cuid())
  paymentIntentId String   @unique
  customerRiskTier String
  ticketSize      String   // SMALL, MEDIUM, LARGE
  selectedPool    String?
  selectedBank    String?
  fallbackUsed    Boolean  @default(false)
  limitsApplied   String?  // JSON
  createdAt       DateTime @default(now())
}

// NEW: Settlement Management
model Settlement {
  id             String   @id @default(cuid())
  merchantId     String
  merchant       Merchant @relation(fields: [merchantId], references: [id])
  totalAmount    Decimal  @db.Decimal(14,2)
  holdAmount     Decimal  @default(0) @db.Decimal(14,2)
  releasedAmount Decimal  @default(0) @db.Decimal(14,2)
  status         String   @default("UNSETTLED") // UNSETTLED, HELD, PARTIAL, SETTLED, PAID_OUT
  settledAt      DateTime?
  paidOutAt      DateTime?
  createdAt      DateTime @default(now())
}
